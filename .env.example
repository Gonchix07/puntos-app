# Copiá este archivo a .env y completá con los datos de tu proyecto Supabase
# (Supabase Dashboard -> Project Settings -> API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-public-key

# Solo para las serverless functions (/api) en Vercel — NO llevan prefijo VITE_
# SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Portal de clientes (/api/portal-*) ---
# Secreto para firmar los tokens de sesión del portal (cualquier string largo y aleatorio)
# PORTAL_TOKEN_SECRET=un-secreto-largo-y-aleatorio
# URL pública de la app (para armar el link de recupero de contraseña)
# PORTAL_URL=https://tu-app.vercel.app
# Envío de mails transaccionales por Brevo (recupero de contraseña)
# BREVO_API_KEY=xkeysib-...
# BREVO_FROM_EMAIL=remitente-verificado@tudominio.com
# BREVO_FROM_NAME=Programa de Puntos
